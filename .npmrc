# Route the @fantom scope to GitHub Packages.
@fantom:registry=https://npm.pkg.github.com

# Auth comes from an env var — NEVER commit a real token.
# Local: export NODE_AUTH_TOKEN=<a GitHub PAT with write:packages>
# CI:    setup-node injects this automatically (see .github/workflows/publish.yml)
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
